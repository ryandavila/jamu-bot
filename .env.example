DISCORD_TOKEN=your_discord_token_here

# --- Database ---
# Option A: a full connection string (Neon, Supabase, RDS, or any managed
# Postgres). When set, this takes precedence over the POSTGRES_* settings below.
# Plain postgres:// / postgresql:// URLs are accepted and rewritten to use the
# asyncpg driver automatically. Neon example:
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/jamu_quotes?sslmode=require

# Option B: individual settings for the local Docker Postgres (used when
# DATABASE_URL is not set).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jamu_quotes
POSTGRES_USER=jamu_bot
POSTGRES_PASSWORD=change_me_in_production

# --- Optional database tuning ---
# Force TLS on/off regardless of the URL ("require" or "disable"). When unset,
# SSL is inferred from the connection string's sslmode.
# DB_SSL=require
# asyncpg prepared-statement cache size. 0 (default) is required behind
# transaction-mode poolers such as Neon's pooled endpoint.
# DB_STATEMENT_CACHE_SIZE=0
# Seconds before a pooled connection is recycled (default 300).
# DB_POOL_RECYCLE=300
